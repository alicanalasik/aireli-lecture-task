63473880fd4f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":9,"operation":"replace","value":"export const createUser = async (user: PlatformUser): Promise<PlatformUser> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(user.password!, 10);\n\n  const result = await db.run(\n    'INSERT INTO users (email, password, firstName, lastName) VALUES (?, ?, ?, ?)',\n    user.email,\n    hashedPassword,\n    null,\n    null\n  );\n\n  const createdUser = await db.get<PlatformUser>(\n    'SELECT * FROM users WHERE id = ?',\n    result.lastID\n  );\n\n  await db.close();\n\n  return createdUser as PlatformUser;\n};","rangeOffset":"136","rangeLength":"545","rangestart_line":"4","rangestart_character":"0","rangeend_line":"25","rangeend_character":"2"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"DocumentSaveEvent","eventTime":1773786016243,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":9,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773786033376,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773786043394,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516