,{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773785628976,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773785695924,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773785756502,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773785758505,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"DocumentChangeEvent","eventTime":1773785760782,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":9,"operation":"delete","value":"","rangeOffset":"0","rangeLength":"777","rangestart_line":"0","rangestart_character":"0","rangeend_line":"28","rangeend_character":"2"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"DocumentChangeEvent","eventTime":1773785761152,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":9,"operation":"add","value":"import bcrypt from 'bcryptjs';\nimport { PlatformUser } from \"@enterprise-commerce/core/platform/types\";\nimport openDb from '../db/db';\n\nexport const createUser = async (user: PlatformUser): Promise<PlatformUser> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(user.password, 10);\n\n  const result = await db.run(\n    'INSERT INTO users (firstName, lastName, email, password) VALUES (?, ?, ?, ?)',\n    user.firstName,\n    user.lastName,\n    user.email,\n    hashedPassword\n  );\n\n  const createdUser = await db.get<PlatformUser>(\n    'SELECT * FROM users WHERE id = ?',\n    result.lastID\n  );\n\n  await db.close();\n\n  return createdUser as PlatformUser;\n};\n\nexport const findUserById = async (id: string): Promise<PlatformUser | null> => {\n  const db = await openDb();\n  const user = await db.get<PlatformUser>('SELECT * FROM users WHERE id = ?', id);\n  await db.close();\n  return user || null;\n};\n\n/**\n * Compares a plain text password with a hashed password.\n *\n * @param {string} password\n * @param {string} hashedPassword\n * @returns {Promise<boolean>}\n */\nexport const comparePasswords = async (password: string, hashedPassword: string): Promise<boolean> => {\n  return bcrypt.compare(password, hashedPassword);\n};\nSonra\n\nkaydet\n\nterminale bak\n\napp crashed gitmeli.\n\nSonra bana hemen auth.controller.ts içeriğini at.\n\nimport sqlite3 from 'sqlite3';\nimport { open, Database } from 'sqlite';\nimport path from 'path';\nimport bcrypt from 'bcryptjs';\nimport { PlatformUser } from \"@enterprise-commerce/core/platform/types\"\nimport openDb from '../db/db';\n\nexport const createUser = async (user: PlatformUser): Promise<PlatformUser> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(user.password, 10);\n\n  const result = await db.run(\n    'INSERT INTO users (firstName, lastName, email, password) VALUES (?, ?, ?, ?)',\n    user.firstName,\n    user.lastName,\n    user.email,\n    hashedPassword\n  );\n\n  const createdUser = await db.get<PlatformUser>(\n    'SELECT * FROM users WHERE id = ?',\n    result.lastID\n  );\n\n  await db.close();\n\n  return createdUser as PlatformUser;\n};\n\nEvet, dosyanın geri kalanı silinmiş. Şu an findUserById ve comparePasswords yok, o yüzden crash alıyorsun.\n\nHiç uğraşma: User.ts dosyasının tamamını sil ve bunu baştan sona yapıştır:\n\nimport bcrypt from 'bcryptjs';\nimport { PlatformUser } from \"@enterprise-commerce/core/platform/types\";\nimport openDb from '../db/db';\n\nexport const createUser = async (user: PlatformUser): Promise<PlatformUser> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(user.password, 10);\n\n  const result = await db.run(\n    'INSERT INTO users (firstName, lastName, email, password) VALUES (?, ?, ?, ?)',\n    user.firstName,\n    user.lastName,\n    user.email,\n    hashedPassword\n  );\n\n  const createdUser = await db.get<PlatformUser>(\n    'SELECT * FROM users WHERE id = ?',\n    result.lastID\n  );\n\n  await db.close();\n\n  return createdUser as PlatformUser;\n};\n\nexport const findUserById = async (id: string): Promise<PlatformUser | null> => {\n  const db = await openDb();\n  const user = await db.get<PlatformUser>('SELECT * FROM users WHERE id = ?', id);\n  await db.close();\n  return user || null;\n};\n\nexport const comparePasswords = async (\n  password: string,\n  hashedPassword: string\n): Promise<boolean> => {\n  return bcrypt.compare(password, hashedPassword);\n};","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"DocumentSaveEvent","eventTime":1773785766690,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":9,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773785797272,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"WindowStateChangeEvent","eventTime":1773785834240,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"solid-garbanzo-455j7j4wwx53qgv","eventName":"DocumentChangeEvent","eventTime":1773785839789,"sessionId":"213b176f-cd9b-4036-b53f-749c7317726f1773783558853","machineId":"cd65164dc947a79f95bd6616ee1b9efc516ad24080d92e9e827463473880fd4f","docume